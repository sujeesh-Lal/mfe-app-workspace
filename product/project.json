{
  "name": "product",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "product/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "compiler": "babel",
        "outputPath": "product/dist",
        "index": "product/src/index.html",
        "baseHref": "/",
        "main": "product/src/main.ts",
        "tsConfig": "product/tsconfig.app.json",
        "assets": [
          "product/src/favicon.ico",
          "product/src/assets"
        ],
        "styles": [
          "product/src/styles.css"
        ],
        "scripts": [],
        "webpackConfig": "product/webpack.config.ts"
      },
      "configurations": {
        "development": {
          "extractLicenses": false,
          "optimization": false,
          "sourceMap": true,
          "vendorChunk": true
        },
        "production": {
          "fileReplacements": [
            {
              "replace": "product/src/environments/environment.ts",
              "with": "product/src/environments/environment.prod.ts"
            }
          ],
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": false,
          "namedChunks": false,
          "extractLicenses": true,
          "vendorChunk": false,
          "webpackConfig": "product/webpack.config.prod.ts"
        }
      },
      "dependsOn": [
        "^build",
        "typecheck"
      ]
    },
    "serve": {
      "executor": "@nx/react:module-federation-dev-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "product:build",
        "hmr": true,
        "port": 4201
      },
      "configurations": {
        "development": {
          "buildTarget": "product:build:development"
        },
        "production": {
          "buildTarget": "product:build:production",
          "hmr": false
        }
      },
      "dependsOn": [
        "typecheck"
      ]
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve-static": {
      "executor": "@nx/react:module-federation-static-server",
      "defaultConfiguration": "production",
      "options": {
        "serveTarget": "product:serve"
      },
      "configurations": {
        "development": {
          "serveTarget": "product:serve:development"
        },
        "production": {
          "serveTarget": "product:serve:production"
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{projectRoot}/test-output/jest/coverage"
      ],
      "options": {
        "jestConfig": "product/jest.config.ts"
      }
    }
  }
}
